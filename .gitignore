# Create .gitignore
cat > .gitignore << EOL
# dependencies
node_modules/
package-lock.json
yarn.lock

# Expo
.expo/
.expo-shared/
web-build/
dist/

# Native
ios/Pods/
ios/DerivedData/
android/app/build/
android/.gradle/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment
.env
.env.local
.env.*.local

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
*.jsbundle
*.ipa
*.apk
EOL